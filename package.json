{
  "author": "Kevin De Benedetti",
  "type": "module",
  "devDependencies": {
    "@j178/prek": "^0.3.5",
    "@types/bun": "^1.3.10",
    "@types/node": "^25.5.0",
    "oxlint": "^1.55.0",
    "typescript": "^5.9.3",
    "vitepress": "^1.6.4",
    "vue-tsc": "^3.2.5",
    "yaml": "^2.8.1"
  },
  "scripts": {
    "sync-docs": "bun scripts/sync-docs.ts",
    "docs:dev": "bun run generate && vitepress dev",
    "docs:build": "bun run generate && vitepress build",
    "docs:preview": "vitepress preview",
    "generate": "bun run sync-docs && bun scripts/generate-config.ts",
    "build": "bun run docs:build",
    "lint": "bunx prek run --all-files",
    "typecheck": "vue-tsc --noEmit",
    "test": "echo 'No tests configured'"
  },
  "packageManager": "bun@1.2.21"
}
